  {
    "from_ea": "0x140008fb1",
    "from_func": "0x140008130",
    "string_ea": "0x14000d0f8",
    "text": "MDMDiagReport.xml"
  },
  {
    "from_ea": "0x140003eb4",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d250",
    "text": "  Usage1: %ws -out <output folder path>\n"
  },
  {
    "from_ea": "0x140003ec1",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d2b0",
    "text": "      * Output MDM diagnostics info only to given folder path specified in -out parameter.\n"
  },
  {
    "from_ea": "0x140003ed1",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d370",
    "text": "      eg: %ws -out c:\\temp\\outputfolder\n"
  },
  {
    "from_ea": "0x140003eea",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d3d0",
    "text": "  Usage2: %ws -area <area name(s)> -cab <output cab file path>\n"
  },
  {
    "from_ea": "0x140003ef7",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d450",
    "text": "      * Collect predefined area logs and create a log cab to given cab file.\n"
  },
  {
    "from_ea": "0x140003f52",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d6c0",
    "text": "      * Please find all possible areas in registry under:\n"
  },
  {
    "from_ea": "0x140003f6f",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d7d0",
    "text": "      eg: %ws -area Autopilot;Tpm -cab c:\\temp\\AutopilotDiag.cab\n"
  },
  {
    "from_ea": "0x140003f88",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d860",
    "text": "  Usage3: %ws -area <area name(s)> -zip <output zip file path>\n"
  },
  {
    "from_ea": "0x140003f95",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d8e0",
    "text": "      * Collect predefined area logs and create a log zip to given zip file. Areas supported are the same as Usage2 for creating cab\n"
  },
  {
    "from_ea": "0x140003fae",
    "from_func": "0x140003e94",
    "string_ea": "0x14000d9f0",
    "text": "  Usage4: %ws -xml <xml file of information to gather> -zip <output zip file path> -server <MDM Server to alert>\n"
  },
  {
    "from_ea": "0x140003fbb",
    "from_func": "0x140003e94",
    "string_ea": "0x14000dae0",
    "text": "      * Collect information specified in the xml and create a log zip to given zip file. \n"
  },
  {
    "from_ea": "0x140004adb",
