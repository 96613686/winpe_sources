    "string_ea": "0x1801f7f48",
    "text": "D3D11CreateDevice: Flags (0x"
  },
  {
    "from_ea": "0x1800ebaa8",
    "from_func": "0x180059bcc",
    "string_ea": "0x1801f7f90",
    "text": ") were specified which require the D3D11 SDK Layers for Windows 10, but they are not present on the system.\nThese flags must be removed, or the Windows 10 SDK must be installed.\n"
  },
  {
    "from_ea": "0x1800ebad1",
    "from_func": "0x180059bcc",
    "string_ea": "0x1801f8118",
    "text": "D3D11_CREATE_DEVICE_DEBUG"
  },
  {
    "from_ea": "0x1800ebaf5",
    "from_func": "0x180059bcc",
    "string_ea": "0x1801f8158",
    "text": "D3D11_CREATE_DEVICE_DEBUGGABLE"
  },
  {
    "from_ea": "0x18004ac6d",
    "from_func": "0x18004ac20",
    "string_ea": "0x1801f81e0",
    "text": "\nD3D11 ERROR: D3D11 header version mismatch.\nThe application was compiled against and will only work with D3D11_SDK_VERSION (%d), but the currently installed runtime is version (%d).\nRecompile the application against the appropriate SDK for the installed runtime.\n\n"
  },
  {
    "from_ea": "0x18004a780",
    "from_func": "0x18004a74c",
    "string_ea": "0x1801f82f0",
    "text": "DXGIDebug.dll"
  },
  {
    "from_ea": "0x1800d4a3b",
    "from_func": "0x1800d4a14",
    "string_ea": "0x1801f82f0",
    "text": "DXGIDebug.dll"
  },
  {
    "from_ea": "0x1800af6da",
    "from_func": "0x1800af3d4",
    "string_ea": "0x1801f83b0",
    "text": "Error querying DXDB for size of DX_DATABASE_CONFIG_QUERY_TYPE_FORCE_11ON12_DEVICE_LIST"
  },
  {
    "from_ea": "0x1800af456",
    "from_func": "0x1800af3d4",
    "string_ea": "0x1801f8460",
    "text": "DX_DATABASE_CONFIG_QUERY_TYPE_FORCE_11ON12_DEVICE_LIST dataSize was not a multiple of 2. Increasing dataSize by one."
  },
  {
    "from_ea": "0x1800af6bd",
    "from_func": "0x1800af3d4",
    "string_ea": "0x1801f8550",
    "text": "Error querying DXDB for DX_DATABASE_CONFIG_QUERY_TYPE_FORCE_11ON12_DEVICE_LIST"
  },
  {
    "from_ea": "0x1800a5e47",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f85f0",
    "text": "D3D11On12CreateDevice: You must specify a D3D12 device."
  },
  {
    "from_ea": "0x1800a652b",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f8630",
    "text": "D3D11On12CreateDevice: The device provided is not a valid D3D12 device."
  },
  {
    "from_ea": "0x1800a5ea9",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f8680",
    "text": "D3D11On12CreateDevice: The output parameter pChosenFeatureLevel must not overlap with the input paramteter array pFeatureLevels."
  },
  {
    "from_ea": "0x1800a5f05",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f8710",
    "text": "D3D11On12CreateDevice: The NodeMask parameter must only have a single bit set."
  },
  {
    "from_ea": "0x1800a5f3e",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f8760",
    "text": "D3D11On12CreateDevice: If NumQueues is nonzero, ppCommandQueues must be non-null, and vice versa."
  },
  {
    "from_ea": "0x1800a6079",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f87d0",
    "text": "D3D11On12CreateDevice: Not all command queues provided are valid D3D12 command queues."
  },
  {
    "from_ea": "0x1800a602d",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f8830",
    "text": "D3D11On12CreateDevice: When D3D11_CREATE_DEVICE_DISABLE_GPU_TIMEOUT is set, all provided command queues must have been created with D3D12_COMMAND_QUEUE_FLAG_DISABLE_GPU_TIMEOUT."
  },
  {
    "from_ea": "0x1800a6070",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f88f0",
    "text": "D3D11On12CreateDevice: All command queues provided must target the node specified by NodeMask."
  },
  {
    "from_ea": "0x1800a6067",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f8950",
    "text": "D3D11On12CreateDevice: Unsupported command queue type provided."
  },
  {
    "from_ea": "0x1800a605e",
    "from_func": "0x1800a5d80",
    "string_ea": "0x1801f8990",
    "text": "D3D11On12CreateDevice: Only a single command queue of each type per node may be provided."
  },
  {
    "from_ea": "0x1800aecc3",
    "from_func": "0x1800aec50",
    "string_ea": "0x1801f89f0",
    "text": "D3D11CreateDeviceForD3D12: You must specify a D3D12 device."
  },
  {
    "from_ea": "0x1800aedbe",
    "from_func": "0x1800aec50",
    "string_ea": "0x1801f8a30",
    "text": "D3D11CreateDeviceForD3D12: The device provided is not a valid D3D12 device."
  },
  {
    "from_ea": "0x1800aed29",
    "from_func": "0x1800aec50",
    "string_ea": "0x1801f8a80",
    "text": "D3D11CreateDeviceForD3D12: The output parameter pChosenFeatureLevel must not overlap with the input paramteter array pFeatureLevels."
  },
  {
    "from_ea": "0x1800aed66",
    "from_func": "0x1800aec50",
    "string_ea": "0x1801f8b10",
    "text": "D3D11CreateDeviceForD3D12: The NodeMask parameter must only have a single bit set."
  },
  {
    "from_ea": "0x1800accf0",
    "from_func": "0x1800acb94",
    "string_ea": "0x1801f8b68",
    "text": "D3D11On12CreateDeviceGenerated"
  },
  {
    "from_ea": "0x1800aceb0",
    "from_func": "0x1800acd54",
    "string_ea": "0x1801f8b68",
    "text": "D3D11On12CreateDeviceGenerated"
  },
  {
    "from_ea": "0x1800accdf",
    "from_func": "0x1800acb94",
    "string_ea": "0x1801f8b88",
    "text": "GetRealPtrPtrD3D11On12CreateDevice"
  },
  {
    "from_ea": "0x1800ace9f",
    "from_func": "0x1800acd54",
    "string_ea": "0x1801f8b88",
    "text": "GetRealPtrPtrD3D11On12CreateDevice"
  },
  {
    "from_ea": "0x18004a594",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f8bc0",
    "text": "D3D11CreateDevice: The output parameter pFeatureLevel must not overlap with the input paramteter array pFeatureLevels."
  },
  {
    "from_ea": "0x18004a5b6",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f8c40",
    "text": "D3D11CreateDevice: There's no reason to pass in an array larger than %d elements, as it implies that either certain D3D_FEATURE_LEVELs will be tried multiple times or never succeed. FeatureLevels was set to %d. Only D3D_FEATURE_LEVEL_9_1, D3D_FEATURE_LEVEL_9_2, D3D_FEATURE_LEVEL_9_3, D3D_FEATURE_LEVEL_10_0, D3D_FEATURE_LEVEL_10_1, D3D_FEATURE_LEVEL_11_0, D3D_FEATURE_LEVEL_11_1, D3D_FEATURE_LEVEL_12_0,  D3D_FEATURE_LEVEL_12_1 and D3D_FEATURE_LEVEL_12_2 are recognized."
  },
  {
    "from_ea": "0x18004a654",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f8ec0",
    "text": "D3D11CreateDevice: The adapter obtained via IDXGIDevice::GetAdapter from a D3D_FEATURE_LEVEL_9_* device can only be used to create other feature level 9 devices.  Because this device creation call only requests feature level 10 or higher it will fail."
  },
  {
    "from_ea": "0x1800eab54",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f8fc0",
    "text": "D3D11CreateDevice: The adapter obtained via IDXGIDevice::GetAdapter from a D3D_FEATURE_LEVEL_9_* device can only be used to create other feature level 9 devices.  Higher feature levels are being ignored."
  },
  {
    "from_ea": "0x18004a671",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f9090",
    "text": "D3D11CreateDevice: When creating a device from an existing adapter (i.e. pAdapter is non-NULL), DriverType must be D3D_DRIVER_TYPE_UNKNOWN."
  },
  {
    "from_ea": "0x18004a686",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f9120",
    "text": "D3D11CreateDevice: When creating a device without an adapter (i.e. pAdapter is NULL), the DriverType designates the type of adapter to use; and must not be D3D_DRIVER_TYPE_UNKNOWN."
  },
  {
    "from_ea": "0x18004a540",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f91e0",
    "text": "D3D11CreateDevice: When creating a D3D_DRIVER_TYPE_SOFTWARE device, Software handle must be non-NULL."
  },
  {
    "from_ea": "0x18004a59d",
    "from_func": "0x18004a080",
    "string_ea": "0x1801f9250",
    "text": "D3D11CreateDevice: When creating a non-D3D_DRIVER_TYPE_SOFTWARE device, Software handle must be NULL."
  },
